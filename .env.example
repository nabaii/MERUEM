# Copy this file to .env and fill in real values

# Security — generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32

# Twitter / X API credentials (Basic tier)
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAPKI8gEAAAAAa4GYXeCGMehvqhn3m6WLDsFYqic%3DRy9rUuW2NzU4vvt5H7YK9tCONi0YtlNpEBtuFCHsxaZDIowjfT
TWITTER_API_KEY=vLueBmI8BsBRLQt3gBJpmpU8G
TWITTER_API_SECRET=KAvQWCW1Pc8UXiyHtxrh1AoLlLIQkrWv9TfFRyBX7wG4BbXTgN
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Object storage — set to false for S3/DO Spaces in production
OBJECT_STORAGE_LOCAL=true
OBJECT_STORAGE_BUCKET=meruem-raw
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=     # Leave blank for AWS; set for DO Spaces e.g. https://nyc3.digitaloceanspaces.com

# Instagram Graph API (Phase 6)
INSTAGRAM_ACCESS_TOKEN=        # Long-lived Page Access Token with instagram_basic permission
INSTAGRAM_GRAPH_API_VERSION=v19.0

# Sentry error tracking (Phase 6 — optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# API rate limiting (Phase 6)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=200/minute

# Production Postgres (used by docker-compose.prod.yml)
POSTGRES_USER=meruem
POSTGRES_PASSWORD=change_in_production
POSTGRES_DB=meruem
GRAFANA_PASSWORD=change_in_production
DOMAIN=yourdomain.com

# SMTP email (optional — notifications are skipped if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@meruem.app
SMTP_TLS=true

# Anthropic profiling
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com/v1/messages
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIMEOUT_SECONDS=30
PROFILING_RATE_LIMIT_PER_MINUTE=50
PROFILING_MAX_PROFILES_PER_RUN=500

# App settings
DEBUG=false
